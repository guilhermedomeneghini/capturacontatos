{
  "name": "captar-contatos",
  "version": "1.0.0",
  "description": "Sistema local para captar leads publicos a partir de buscas no Google Maps.",
  "main": "dist/server.js",
  "scripts": {
    "postinstall": "playwright install chromium",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "leads",
    "google-maps",
    "playwright",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2",
    "lucide": "^0.468.0",
    "playwright": "^1.49.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
